# ── Ollama ────────────────────────────────────────────────────────────────────
# Ollama must be running locally. Default model is qwen2.5:7b.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:32b

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite file path (relative to backend/ directory)
DB_PATH=portfolio.db

# ── Stock APIs ─────────────────────────────────────────────────────────────────
# All optional — yfinance is used as primary (free, no key needed).
# Alpha Vantage: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=

# Polygon.io: https://polygon.io/dashboard/signup
POLYGON_KEY=

# ── News API ───────────────────────────────────────────────────────────────────
# Optional — yfinance news is used as fallback when not set.
# NewsAPI: https://newsapi.org/register
NEWS_API_KEY=
