# Copy to .env for local runs. Never commit the real .env.
KALLANG_EMAIL=your.email@example.com
KALLANG_PASSWORD=your-password

# Optional
HEADLESS=1        # 0 to watch the browser locally
DRY_RUN=0         # 1 = stop before final "Confirm booking" click
MIN_START=19      # 24h, inclusive (7pm)
MAX_START=21      # 24h, inclusive — last valid 60-min start (9pm ends at 10pm)
DURATION_MIN=60
MAX_DAYS_AHEAD=14 # scan this many days forward
